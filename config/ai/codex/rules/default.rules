# Deny-list approach: sandbox is the primary defense line.
# Only block or prompt for known dangerous operations.

# --- Forbidden: too destructive for automation ---
prefix_rule(pattern=["dd"], decision="forbidden", justification="Raw disk writes are too destructive for agent automation.")
prefix_rule(pattern=["mkfs"], decision="forbidden", justification="Filesystem formatting is too destructive for agent automation.")

# --- Prompt: high-blast-radius operations need review ---
prefix_rule(pattern=["sudo"], decision="prompt", justification="Privilege escalation should be reviewed.")
prefix_rule(pattern=["rm"], decision="prompt", justification="Deletion should be reviewed.")
prefix_rule(pattern=["find"], decision="prompt", justification="find can delete or rewrite many files with flags such as -delete or -exec.")
prefix_rule(pattern=["git", "clean"], decision="prompt", justification="git clean can permanently delete untracked files.")
prefix_rule(pattern=["git", "reset", "--hard"], decision="prompt", justification="Hard reset discards worktree changes.")
prefix_rule(pattern=["git", "push", "--force"], decision="prompt", justification="Force-push can overwrite remote history.")
prefix_rule(pattern=["git", "push", "--force-with-lease"], decision="prompt", justification="Force-push can overwrite remote history.")
prefix_rule(pattern=["chmod", "-R"], decision="prompt", justification="Recursive permission changes have broad side effects.")
prefix_rule(pattern=["chown", "-R"], decision="prompt", justification="Recursive ownership changes have broad side effects.")
